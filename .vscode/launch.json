        {
            // --- 这是我们新增的“附加”配置 ---
            "name": "(gdb) 附加到ROS节点",
            "type": "cppdbg",
            "request": "attach",
            // 目标可执行文件的路径，用于加载调试符号
            // "program": "${workspaceFolder}/devel/lib/global_fusion/V1psr_dgps_doppler_fusion_ARAIM_node",
            // "program": "${workspaceFolder}/devel/lib/global_fusion/V4psr_dgps_doppler_fusion_ARAIM_node",
            "program": "${workspaceFolder}/../../devel/lib/fastlio_localization/fastlio_mapping",
            // 使用 VSCode 的命令来弹出进程选择列表
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            // 关键：在启动这个调试会话之前，必须先执行tasks.json中定义的任务
            // "preLaunchTask": "ROS: Launch Target Node"
            // 加上下面这个可以避免一些不必要的日志终端
            "logging": {
                "engineLogging": false,
                "programOutput": false, // 程序输出已经在它自己的终端里了
                "exceptions": false
            }
